{
  "name": "txio-monorepo",
  "private": true,
  "scripts": {
    "dev:backend": "cd backend/api && cargo run",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:desktop": "cd desktop && npm start",
    "build": "npm run build --workspace frontend && node scripts/copy-frontend-out.mjs",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "workspaces": [
    "frontend",
    "desktop"
  ],
  "overrides": {
    "axios": "^1.18.1",
    "form-data": "^4.0.6",
    "ws": "^8.20.2",
    "postcss": "^8.5.14",
    "typescript": "5.9.3",
    "sharp": "^0.35.3",
    "next": {
      "postcss": "^8.5.20"
    }
  }
}
